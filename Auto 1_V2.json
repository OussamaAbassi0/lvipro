      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst competitorName = $('⚙️ Extraire URN').first().json.competitor_name || $('⚙️ Extraire URN1').first().json.competitor_name || '';\nconst competitorUrl  = $('⚙️ Extraire URN').first().json.linkedin_url  || $('⚙️ Extraire URN1').first().json.linkedin_url  || '';\n\nif (response.success === false || response.statusCode >= 400) {\n  return [{ json: { _no_posts: true, error: response.message || response.error || JSON.stringify(response), _competitor_name: competitorName, _competitor_url: competitorUrl }, pairedItem: { item: 0 } }];\n}\n\nlet posts = [];\nconst d = response.data;\nif (Array.isArray(d)) posts = d;\nelse if (d && Array.isArray(d.elements)) posts = d.elements;\nelse if (d && Array.isArray(d.posts)) posts = d.posts;\nelse if (d && Array.isArray(d.items)) posts = d.items;\nelse if (Array.isArray(response.elements)) posts = response.elements;\nelse if (Array.isArray(response)) posts = response;\n\nif (posts.length === 0) {\n  return [{ json: { _no_posts: true, _competitor_name: competitorName, _competitor_url: competitorUrl }, pairedItem: { item: 0 } }];\n}\n\nreturn posts.slice(0, 15).map(post => ({ json: { ...post, _competitor_name: competitorName, _competitor_url: competitorUrl }, pairedItem: { item: 0 } }));"
      },
