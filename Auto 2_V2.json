    {
      "parameters": {
        "jsCode": "const body = $input.first().json;\nlet leads = [];\nif (body.body && Array.isArray(body.body.leads)) leads = body.body.leads;\nelse if (Array.isArray(body.leads)) leads = body.leads;\nelse if (Array.isArray(body.body)) leads = body.body;\nif (leads.length === 0) return [];\nreturn leads.map(lead => ({ json: lead }));"
      },
